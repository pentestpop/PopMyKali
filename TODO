#Install Signal on Arch
# 1. Install base-devel (if you haven't already)
sudo pacman -S --needed base-devel git
# 2. Clone the Signal package build
git clone https://aur.archlinux.org/signal-desktop.git
# 3. Enter the directory
cd signal-desktop
# 4. Build and install (this handles dependencies automatically)
makepkg -si
